# Terraform working directories
**/.terraform/*
.terraform/

# Terraform local state - never commit
*.tfstate
*.tfstate.*

# Terraform crash/debug logs
crash.log
crash.*.log

# Terraform plan files
*.tfplan
tfplan
plan.out

# Secret/local variable files
secrets.tfvars
secrets.tfvars.json
secrets.auto.tfvars
secrets.auto.tfvars.json
*.secret.tfvars
*.secret.tfvars.json

# Local environment files
.env
.env.*
!.env.example
.envrc

# Terraform override files - usually local-only
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terragrunt cache, even if not using Terragrunt now
.terragrunt-cache/
terragrunt-debug.tfvars.json

# Editor/OS junk
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Logs
*.log
